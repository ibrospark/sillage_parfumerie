{# templates/pages/show.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}{{ page.title }}{% endblock %}

{% block body %}
    <div class="container p-4">
        {# BREADCRUMBS #}
    {% set breadcrumbs = [
        {"page_name": "Accueil", "route_path": path('home.index')},
        {"page_name": page.title, "route_path": path('product.index')},
    ] %}
    {% include 'components/_breadcrumb.html.twig' with {'breadcrumbs': breadcrumbs} %}

    {# TITLE #}
    {% include 'components/_title_with_subtitle.html.twig' with {
        'title': page.title,
        'subtitle': ''
    } %}

    <div class="row">
 
        {% if page.imageUrl %}
    <div class="col-lg-6 col-md-6 px-4"
    style="
    background-image: url('{{ asset('img/pages/' ~ page.imageUrl) }}'); 
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    min-height:300px;
    ">
        <!-- Contenu de la div, si nécessaire -->
    </div>

        {% endif %}
        <div class="col-lg-6 col-md-6 px-4">
            {{ page.content|raw }}
        </div>

    </div>
    
    </div>
{% endblock %}
