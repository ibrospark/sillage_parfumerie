{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
    {% for flash_error in app.flashes('verify_email_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
<div class="container p-4">
{# BREADCRUMBS ------------------------------------------------------------------------------------------------ #}
  {% set breadcrumbs = [
      {"page_name": "Accueil", "route_path": path('home.index')},
      {"page_name": "Inscription", "route_path": path('app_register')},
  ] %}
  {% include 'components/_breadcrumb.html.twig' 
      with {'breadcrumbs': breadcrumbs ? breadcrumbs : null} 
  %} 
<div class="row justify-content-center">
  <div class="col-12 col-sm-12 col-md-6 col-lg-6 border p-5">

        <h1>Inscription</h1>

    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm) }}
        {{ form_row(registrationForm.firstname) }}
        {{ form_row(registrationForm.lastname) }}
        {{ form_row(registrationForm.email) }}
        {{ form_row(registrationForm.plainPassword, {
            label: 'Mot de passe'
        }) }}
        {{ form_row(registrationForm.agreeTerms) }}

        <button type="submit" class="spkdv_primary_btn">Inscription</button>
    {{ form_end(registrationForm) }}
  </div>
</div>

</div>
{% endblock %}
