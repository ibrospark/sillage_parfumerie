{% extends 'base.html.twig' %}

{% block title %}Box Sillage - Parfums{% endblock %}

{% block body %}
<div class="container p-4">
    {# BREADCRUMBS #}
    {% set breadcrumbs = [
        {"page_name": "Accueil", "route_path": path('home.index')},
        {"page_name": "Box Sillage", "route_path": path('box_sillage.index')},
    ] %}
    {% include 'components/_breadcrumb.html.twig' with {'breadcrumbs': breadcrumbs} %}

    {# TITLE #}
    {% include 'components/_title_with_subtitle.html.twig' with {
        'title': 'Box Sillage',
        'subtitle': 'Découvrez une sélection exclusive de parfums rares'
    } %}



    <div class="spkdv_product_grid">
        <div class="row">
            {% for product in pagination %}
                <div class="col-6 col-sm-6 col-md-4 col-lg-3">
                    {% include 'product/_product_grid_template.html.twig' 
                        with {
                            'product': product ? product : null
                        } 
                    %}
                </div>
            {% else %}
                <div class="alert alert-warning">
                    Aucun produit disponible pour le moment.
                </div>
            {% endfor %}
            <div class="spkdv_pagination py-5">
                <center>
                    {{ knp_pagination_render(pagination) }}
                </center>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

{% endblock %}
