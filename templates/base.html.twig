<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Welcome!{% endblock %}</title>
    
    {# Favicon --------------------------------------------------------------- #}
    <link rel="icon" href="{{ asset('img/icon2.png') }}" type="image/x-icon">
    
    {# Bootstrap - CSS --------------------------------------------------------------- #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    {# Google Fonts --------------------------------------------------------------- #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=DM+Sans:wght@100;200;300;400;500;600;700;800;900&family=Libre+Baskerville:wght@400;700&family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    {# Swiper - CSS --------------------------------------------------------------- #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    
    {# CSS Personnel --------------------------------------------------------------- #}
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    <link rel="stylesheet" href="{{ asset('css/mega_menu.css') }}">

    {# Font Awesome --------------------------------------------------------------- #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    {# Twig Stylesheets --------------------------------------------------------------- #}
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

</head>
<body>

    {# Header --------------------------------------------------------------- #}
    {% include 'components/_header.html.twig' %}
    
    {# Main Body --------------------------------------------------------------- #}
    {% block body %}{% endblock %}

<style>
/* -------------------------------------- WHATSAPP -------------------------------------- */
.whatsapp-button {
    position: fixed;
    bottom: 5%;
    right: 3%;
    width: 60px;
    height: 60px;
    background-color: #25d366;
    /* Couleur WhatsApp */
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    z-index: 9999;
}

.whatsapp-button img {
    width: 35px;
    height: 35px;
}

</style>

    <a href="https://wa.me/11234567890" target="_blank" class="whatsapp-button">
        <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" loading="lazy" alt="WhatsApp" />
    </a>

    {# Footer --------------------------------------------------------------- #}
    {% include 'components/_footer.html.twig' %}

    {# Custom JavaScript --------------------------------------------------------------- #}
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
        <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
        <script src="{{ asset('js/swiper.js') }}"></script>
        <script src="{{ asset('assets/js/bootstrap.bundle.js') }}"></script>
    {% endblock %}

</body>
</html>
