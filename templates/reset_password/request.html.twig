{% extends 'base.html.twig' %}

{% block title %}Réinitialisez votre mot de passe{% endblock %}

{% block body %}
<div class="container p-4">
    {% for flash_error in app.flashes('reset_password_error') %}
    <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}

    {# TITLE------------------------------------------------------------------------------------------------ #}
  {% include 'components/_title_with_subtitle.html.twig' 
    with {
      'title': 'Réinitialisez votre mot de passe',
      'subtitle': 'Entrez votre adresse E-mail, et nous vous transférerons un lien de réinitialisation de votre mot de passe.'
    } 
  %}

    {{ form_start(requestForm) }}
    {{ form_row(requestForm.email) }}
    <button class="spkdv_primary_btn_outline">Envoyer l'e-mail de réinitialisation</button>
    {{ form_end(requestForm) }}
</div>
{% endblock %}
