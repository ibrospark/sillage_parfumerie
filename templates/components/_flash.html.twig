{% set flashTypes = ['success', 'error', 'warning', 'info'] %} 
{% for type in flashTypes %}
    {% set messages = app.flashes(type) %}
    {% if messages is defined and messages | length > 0 %}        
        <div id="message-container">
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} rounded-0 m-3" role="alert">
                    {{ message }}
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endfor %}
