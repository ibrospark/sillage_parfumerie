<form action="{{ path('search.show') }}" method="get" class="position-relative">
    <div class="input-group">
        <!-- Icone cliquable à gauche -->
        <button class="input-group-text bg-transparent border-0" id="search-addon">
            <i class="fas fa-search"></i>
        </button>
        <!-- Champ de recherche -->
        <input type="text" class="form-control rounded-0 bg-transparent border-light border-0 border-bottom " name="s" 
               value="{{ app.request.query.get('s', '') }}" 
               placeholder="Rechercher un produit" 
               aria-describedby="search-addon"
               style="outline: none;
    box-shadow: none;
    border-color: transparent;"
               >
    </div>
</form>
