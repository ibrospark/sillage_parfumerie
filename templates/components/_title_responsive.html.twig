{# _title_responsive.html.twig #}
{% set alignment = 'text-left' %}
{# Appliquer la classe d'alignement dynamiquement en fonction du paramètre 'alignment' #}
<div class="{{ alignment }} py-2">
    <!-- Affichage sur les écrans de type Laptop (large) -> h2 -->
    <h2 class="d-none d-lg-block">{{ content }}</h2>

    <!-- Affichage sur les écrans de type Tablette (medium) -> h3 -->
    <h3 class="d-none d-md-block d-lg-none">{{ content }}</h3>

    <!-- Affichage sur les écrans de type Mobile (small) -> h4 -->
    <h3 class="d-block d-md-none">{{ content }}</h3>
</div>
