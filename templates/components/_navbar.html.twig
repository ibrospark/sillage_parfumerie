    <style>
        /* Personnalisation du Mega Menu */
        .dropdown-menu {
            display: none; /* Masquer le menu par défaut */
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%; /* Prend 100% de la largeur */
            padding: 1rem;
            background-color: #f8f9fa;
            border: 1px solid #ddd;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            z-index: 1000; /* Pour s'assurer que le menu reste visible */
        }

        .dropdown:hover .dropdown-menu {
            display: block; /* Afficher le menu au survol */
        }

        .mega-menu {
            display: flex;
            flex-wrap: wrap; /* Pour que les éléments se replient s'ils ne rentrent pas */
            justify-content: space-between;
            gap: 20px; /* Espacement entre les colonnes */
        }

        .mega-menu > div {
            flex: 1 1 calc(25% - 20px); /* Les colonnes prennent environ 25% de la largeur avec un espacement de 20px */
            min-width: 200px; /* Taille minimale pour éviter qu'elles soient trop petites */
        }

        .mega-menu h5 {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .mega-menu ul {
            padding: 0;
            list-style-type: none;
        }

        .mega-menu li {
            margin-bottom: 5px;
        }

        .mega-menu a {
            text-decoration: none;
            color: #000;
        }

        .mega-menu a:hover {
            text-decoration: underline;
        }

    </style>
